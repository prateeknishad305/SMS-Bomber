# ============================================================
# SERVER CONFIGURATION
# ============================================================
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://localhost:8081

# ============================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_strong_password_here
DB_NAME=smsbomber
DB_SSL=false
DB_POOL_SIZE=10
DB_CONNECTION_TIMEOUT=20000
DB_IDLE_TIMEOUT=30000

# ============================================================
# REDIS CONFIGURATION (Cache & Session)
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0
REDIS_KEY_PREFIX=smsbomber:
REDIS_SESSION_TTL=86400  # 24 hours in seconds

# ============================================================
# JWT AUTHENTICATION
# ============================================================
JWT_SECRET=your_jwt_secret_min_32_characters_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_min_32_characters_here_change_in_production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=sms-bomber-api
JWT_AUDIENCE=sms-bomber-users

# ============================================================
# SMS PROVIDERS (Twilio)
# ============================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_STATUS_CALLBACK_URL=https://api.smsbomber.com/sms/twilio-callback

# ============================================================
# SMS PROVIDERS (Vonage/Nexmo)
# ============================================================
VONAGE_API_KEY=xxxxxxxx
VONAGE_API_SECRET=xxxxxxxxxxxxxxxx
VONAGE_PHONE_NUMBER=+1234567890

# ============================================================
# SMS PROVIDERS (Plivo)
# ============================================================
PLIVO_AUTH_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PLIVO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PLIVO_PHONE_NUMBER=+1234567890

# ============================================================
# QUEUE CONFIGURATION (BullMQ)
# ============================================================
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=your_redis_password_here
QUEUE_CONCURRENCY=5
QUEUE_RETRY_ATTEMPTS=3
QUEUE_RETRY_DELAY=2000
QUEUE_REMOVE_ON_COMPLETE=true
QUEUE_REMOVE_ON_FAIL=true

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_WINDOW=60000  # 1 minute
RATE_LIMIT_MAX=1000      # Max requests per window
RATE_LIMIT_SKIP_SUCCESSFUL=false

# ============================================================
# SECURITY
# ============================================================
BCRYPT_ROUNDS=12
ENCRYPTION_KEY=your_32_char_encryption_key_here_change_in_production
ENCRYPTION_IV_LENGTH=16
HASH_SALT=your_hash_salt_here
CSRF_SECRET=your_csrf_secret_here
SESSION_SECRET=your_session_secret_here

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=info
LOG_RETENTION_DAYS=30
LOG_MAX_FILES=10
LOG_MAX_SIZE=50m
LOG_FORMAT=combined
LOG_FILE_PATH=./logs

# ============================================================
# EMAIL CONFIGURATION (SendGrid)
# ============================================================
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@smsbomber.com
EMAIL_TEMPLATE_VERIFY=verification_email
EMAIL_TEMPLATE_RESET=password_reset
EMAIL_TEMPLATE_WELCOME=welcome_email

# ============================================================
# AWS CONFIGURATION (S3 Backups)
# ============================================================
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1
AWS_S3_BUCKET=sms-bomber-backups
AWS_S3_BACKUP_PREFIX=backups/
AWS_S3_LOGS_PREFIX=logs/

# ============================================================
# MONITORING (Sentry)
# ============================================================
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@ingest.sentry.io/xxxxxx
SENTRY_ENVIRONMENT=production
SENTRY_SAMPLE_RATE=0.1

# ============================================================
# ADMIN ACCOUNT (Initial Setup)
# ============================================================
ADMIN_EMAIL=admin@smsbomber.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!
ADMIN_FULL_NAME=System Administrator

# ============================================================
# FEATURE FLAGS
# ============================================================
FEATURE_WHITELABEL=false
FEATURE_ANALYTICS=true
FEATURE_AUDIT_LOGS=true
FEATURE_SMS_QUEUE=true
FEATURE_BACKUP_AUTO=true

# ============================================================
# EXTERNAL SERVICES
# ============================================================
GOOGLE_RECAPTCHA_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAPBOX_TOKEN=pk.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# DEPLOYMENT SPECIFIC
# ============================================================
# Production
PROD_APP_NAME=sms-bomber-api
PROD_APP_PORT=3000
PROD_SSL_KEY_PATH=/etc/ssl/private/api.smsbomber.com.key
PROD_SSL_CERT_PATH=/etc/ssl/certs/api.smsbomber.com.crt

# Staging
STAGING_APP_NAME=sms-bomber-api-staging
STAGING_APP_PORT=3001

# ============================================================
# DEVELOPMENT
# ============================================================
DEV_SEED_DATA=true
DEV_DROP_DATABASE=false
DEV_ENABLE_DEBUG=true
DEV_SSL=false
